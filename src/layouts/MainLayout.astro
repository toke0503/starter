---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import '../styles/tailwind.css';
import '../styles/animations.css';
const { title = 'Midtfyns Festival', description = 'Midtfyns Festival — af græsrødder og ildsjæle. Festival i Ringe på Fyn med musik, fællesskab og uforglemmelige oplevelser.' } = Astro.props;
---
<html lang="da">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<title>{Astro.props.title}</title>

		<!-- Preconnect: åbner forbindelsen til Adobe Fonts tidligt -->
		<link rel="preconnect" href="https://use.typekit.net" crossorigin />
		<link rel="preconnect" href="https://p.typekit.net" crossorigin />
		<link rel="dns-prefetch" href="https://use.typekit.net" />

		<!-- Fonts — media=print trick: loader non-blocking, skifter til all når hentet -->
		<link rel="stylesheet" href="https://use.typekit.net/vcx4njo.css" media="print" onload="this.media='all'" />
		<noscript><link rel="stylesheet" href="https://use.typekit.net/vcx4njo.css" /></noscript>

		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />

		<!-- Intersect observer: lokal kopi i stedet for unpkg CDN -->
		<script defer src="/observer.min.js"></script>
	</head>
	<body class="">

		<!-- ── Adgangskode-gate ── -->
		<div id="auth-gate">
			<div id="auth-box">
				<p class="auth-label">Midtfyns Festival</p>
				<h2 id="auth-title">Indtast adgangskode</h2>
				<p class="auth-desc">Da dette er et eksamensprojekt, kræver siden en adgangskode for at kunne tilgås.</p>
				<form id="auth-form" autocomplete="off">
					<input
						id="auth-input"
						type="password"
						placeholder="Adgangskode"
						autocomplete="new-password"
						spellcheck="false"
					/>
					<p id="auth-error">Forkert kode — prøv igen</p>
					<button type="submit" id="auth-btn">Gå ind</button>
				</form>
			</div>
		</div>

		<style>
			#auth-gate {
				position: fixed;
				inset: 0;
				z-index: 99999;
				background: var(--color-gron);
				display: flex;
				align-items: center;
				justify-content: center;
				padding: 2rem;
				transition: opacity 0.4s ease;
			}
			#auth-gate.hidden {
				opacity: 0;
				pointer-events: none;
			}
			#auth-box {
				background: var(--color-sand);
				border-radius: 1.5rem;
				padding: 3rem 3.5rem 3.5rem;
				width: 100%;
				max-width: 420px;
				display: flex;
				flex-direction: column;
				gap: 0.5rem;
			}
			.auth-label {
				font-family: var(--font-acumin) !important;
				font-size: 0.95rem !important;
				font-weight: 600;
				text-transform: uppercase;
				letter-spacing: 0.08em;
				color: var(--color-rod) !important;
				margin: 0 0 0.25rem;
				opacity: 0.6;
			}
			#auth-title {
				font-family: var(--font-walnut), serif;
				font-size: clamp(1.75rem, 5vw, 2.5rem);
				color: var(--color-rod);
				text-transform: uppercase;
				line-height: 1;
				margin: 0 0 1.5rem;
			}
			.auth-desc {
				font-family: var(--font-acumin) !important;
				font-size: 1rem !important;
				color: var(--color-rod) !important;
				line-height: 1.6;
				margin: 0 0 1.5rem;
				opacity: 0.75;
			}
			#auth-form {
				display: flex;
				flex-direction: column;
				gap: 0.75rem;
			}
			#auth-input {
				font-family: var(--font-acumin);
				font-size: 1rem;
				color: var(--color-rod);
				background: var(--color-sand);
				border: 1.5px solid var(--color-rod);
				border-radius: 0.75rem;
				padding: 0.9rem 1rem;
				outline: none;
				width: 100%;
				box-sizing: border-box;
				transition: box-shadow 0.2s ease;
			}
			#auth-input:focus {
				box-shadow: 0 0 0 3px rgba(241, 92, 86, 0.2);
			}
			#auth-input::placeholder {
				color: rgba(241, 92, 86, 0.35);
			}
			#auth-error {
				font-family: var(--font-acumin) !important;
				font-size: 0.9rem !important;
				color: var(--color-rod) !important;
				margin: 0;
				opacity: 0;
				transition: opacity 0.2s ease;
			}
			#auth-error.visible {
				opacity: 1;
			}
			#auth-btn {
				font-family: var(--font-acumin);
				font-weight: 600;
				font-size: 1rem;
				text-transform: uppercase;
				letter-spacing: 0.04em;
				color: var(--color-sand);
				background: var(--color-rod);
				border: none;
				border-radius: 3rem;
				padding: 0.9rem 2rem;
				cursor: pointer;
				transition: opacity 0.2s ease;
				margin-top: 0.5rem;
			}
			#auth-btn:hover {
				opacity: 0.85;
			}
		</style>

		<script>
			/*
			 * ── Eksamensgaten ──
			 * Viser et adgangskode-overlay ved sideindlæsning for at beskytte
			 * eksamensprojektet. Koden gemmes i localStorage, så brugeren kun
			 * skal taste koden én gang pr. browser.
			 * Gaten fades ud og fjernes fra DOM'en efter godkendelse (400ms).
			 */
			const gate  = document.getElementById('auth-gate')!;
			const form  = document.getElementById('auth-form')!;
			const input = document.getElementById('auth-input') as HTMLInputElement;
			const error = document.getElementById('auth-error')!;
			const CODE  = 'EKeksamen';

			// Allerede godkendt?
			if (localStorage.getItem('mff-auth') === CODE) {
				gate.classList.add('hidden');
				setTimeout(() => gate.remove(), 400);
			}

			form.addEventListener('submit', (e) => {
				e.preventDefault();
				if (input.value === CODE) {
					localStorage.setItem('mff-auth', CODE);
					gate.classList.add('hidden');
					setTimeout(() => gate.remove(), 400);
				} else {
					error.classList.add('visible');
					input.value = '';
					input.focus();
					setTimeout(() => error.classList.remove('visible'), 2500);
				}
			});
		</script>

		<Header></Header>
		
		<slot />

		<Footer></Footer>

		<!-- ── Eksamensprojekt-popup ── -->
		<!-- inert bruges i stedet for aria-hidden: forhindrer fokus og skærmlæseradgang
		     uden at skabe en modsigelse med fokusérbare børn (aria-hidden + button = Lighthouse-fejl) -->
		<div id="exam-popup" inert>
			<p id="exam-popup-text">Dette er et eksamensprojekt — siden du forsøger at åbne er ikke blevet kodet.</p>
			<button id="exam-popup-close" aria-label="Luk">✕</button>
		</div>

		<style>
			#exam-popup {
				position: fixed;
				bottom: 2rem;
				left: 50%;
				transform: translateX(-50%) translateY(calc(100% + 2rem));
				background: var(--color-gron);
				color: var(--color-sand);
				font-family: var(--font-acumin);
				font-size: 0.95rem;
				padding: 1rem 3rem 1rem 1.5rem;
				border-radius: 0.75rem;
				box-shadow: 0 4px 24px rgba(0,0,0,0.18);
				display: flex;
				align-items: center;
				gap: 1rem;
				z-index: 9999;
				max-width: min(480px, calc(100vw - 2rem));
				transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1), opacity 0.3s ease;
				opacity: 0;
				pointer-events: none;
			}
			#exam-popup.visible {
				transform: translateX(-50%) translateY(0);
				opacity: 1;
				pointer-events: all;
			}
			#exam-popup-text {
				margin: 0;
				line-height: 1.5;
			}
			#exam-popup-close {
				position: absolute;
				top: 0.6rem;
				right: 0.75rem;
				background: none;
				border: none;
				color: var(--color-sand);
				font-size: 0.85rem;
				cursor: pointer;
				opacity: 0.7;
				padding: 0;
				line-height: 1;
			}
			#exam-popup-close:hover { opacity: 1; }
		</style>

		<script>
			/*
			 * ── Eksamensprojekt-popup ──
			 * Viser en toast-meddelelse når brugeren klikker på en knap der ikke
			 * er implementeret (type !== "submit"). Fortæller at siden er et
			 * eksamensprojekt og at den pågældende funktion ikke er kodet.
			 * Popuppen forsvinder automatisk efter 4 sekunder eller ved klik på X.
			 */
			const popup = document.getElementById('exam-popup')!;
			const closeBtn = document.getElementById('exam-popup-close')!;
			let hideTimer: ReturnType<typeof setTimeout>;

			function showPopup() {
				clearTimeout(hideTimer);
				popup.removeAttribute('inert');
				popup.classList.add('visible');
				hideTimer = setTimeout(hidePopup, 4000);
			}

			function hidePopup() {
				popup.classList.remove('visible');
				// inert gensættes når animationen er færdig, så knappen ikke forbliver fokusérbar
				popup.addEventListener('transitionend', () => {
					if (!popup.classList.contains('visible')) popup.setAttribute('inert', '');
				}, { once: true });
			}

			closeBtn.addEventListener('click', () => {
				clearTimeout(hideTimer);
				hidePopup();
			});

			document.addEventListener('click', (e) => {
				const btn = (e.target as Element).closest('button.btn');
				if (btn && (btn as HTMLButtonElement).type !== 'submit') showPopup();
			});

			// href="#" links
			document.querySelectorAll<HTMLAnchorElement>('a.btn[href="#"]').forEach(a => {
				a.addEventListener('click', e => { e.preventDefault(); showPopup(); });
			});
		</script>

		<script>
			/*
			 * ── AI-skabt billede-badges ──
			 * Tilføjer automatisk et lille "AI-skabt"-badge til alle billeder
			 * der er genereret med AI, så brugeren er informeret.
			 * Undtagelser: SVG-filer, dekorative aria-skjulte billeder, kunstner-
			 * pressebilleder og marquee-elementer.
			 * Badget placeres absolut i billedets nærmeste positionerede forfader.
			 * Hvis ingen forfader findes, wrappes billedet i et nyt div-element.
			 */
			(function () {
				// Find første positionerede forfader (ikke html/body)
				// Semantic section/main/article gøres positioned hvis de endnu ikke er det
				function findHost(img: HTMLImageElement): HTMLElement | null {
					let el: HTMLElement | null = img.parentElement;
					for (let i = 0; i < 10 && el; i++) {
						const tag = el.tagName.toLowerCase();
						if (tag === 'html' || tag === 'body') break;
						if (getComputedStyle(el).position !== 'static') return el;
						if (tag === 'section' || tag === 'main' || tag === 'article') {
							el.style.position = 'relative';
							return el;
						}
						el = el.parentElement as HTMLElement;
					}
					return null;
				}

				document.querySelectorAll<HTMLImageElement>('img').forEach(img => {
					// Dekorativt / aria-skjult
					if (img.getAttribute('aria-hidden') === 'true') return;

					// SVG-filer
					if ((img.src || '').includes('.svg')) return;

					// Kunstner-pressebilleder og artist-cards
					if (img.closest('.kunstner-hero, .kunstner-header, .artist-hero, [data-marquee], .artist-card')) return;

					// BW-lag i slideren (ligger under farvebilledet)
					const cls = img.className || '';
					if (cls.includes('-slider-bw') || cls.includes('-overlay')) return;

					const isAbsolute = ['absolute', 'fixed'].includes(getComputedStyle(img).position);
					const host = findHost(img);

					if (host) {
						// Ét badge pr. host-element (undgå dubletter ved delte forfædre)
						if (!host.querySelector('.ai-badge')) {
							const badge = document.createElement('span');
							badge.className = 'ai-badge';
							badge.setAttribute('aria-hidden', 'true');
							badge.textContent = 'AI-skabt';
							// Sektionsbaggrunde: placér badge under header i stedet for bunden,
							// så bølger fra næste sektion (z-index: 10) ikke dækker badget over
							const hostTag = host.tagName.toLowerCase();
							if (hostTag === 'section' || hostTag === 'main') {
								badge.style.bottom = 'auto';
								badge.style.top = '5.5rem';
							}
							host.appendChild(badge);
						}
					} else if (!isAbsolute) {
						// Fallback for billeder direkte i body (f.eks. fuld-bredde-billeder)
						const parent = img.parentElement!;
						const wrap = document.createElement('div');
						wrap.className = 'ai-img-wrap';
						parent.insertBefore(wrap, img);
						wrap.appendChild(img);
						const badge = document.createElement('span');
						badge.className = 'ai-badge';
						badge.setAttribute('aria-hidden', 'true');
						badge.textContent = 'AI-skabt';
						wrap.appendChild(badge);
					}
				});
			})();
		</script>

		<script>
			/*
			 * ── Scroll-animationer ──
			 * Tildeler data-anim attributter til elementer ud fra en prioriteret
			 * animations-map (ANIM_MAP). Første match vinder.
			 * Animationstyper: "heading" (translateY 40px), "up" (22px), "scale" (0.95),
			 * "fade" (kun opacity). Søskende animerer forskudt via stagger-delay.
			 * IntersectionObserver trigger .is-visible-klassen når elementet ruller ind
			 * — CSS-overgangene i animations.css håndterer selve animationen.
			 * Deaktiveres automatisk for brugere med prefers-reduced-motion.
			 */
			(function () {
				if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

				// Klasser der ikke skal animeres
				const SKIP = [
					'-bg', '-overlay', '-wave-', '-aaringe', '-mascot',
					'-deko', '-spacer', '-line', '-knob', '-handle',
					'-slider-color', '-slider-bw', '-hero-bg', '-clip',
				];

				function shouldSkip(el: Element): boolean {
					if (el.getAttribute('aria-hidden') === 'true') return true;
					if (el.closest('[data-marquee]')) return true;
					const c = typeof el.className === 'string'
						? el.className
						: ((el.className as SVGAnimatedString)?.baseVal ?? '');
					return SKIP.some(p => c.includes(p));
				}

				// Animationstype pr. selektor — rækkefølge afgør prioritet (første match vinder)
				const ANIM_MAP: Array<{ sel: string; type: string }> = [
					{ sel: 'h1, h2, h3',                    type: 'heading' },
					{ sel: 'section p, section ul',          type: 'up'      },
					{ sel: '.btn',                           type: 'up'      },
					{ sel: '.artist-card',                   type: 'scale'   },
					{ sel: '.om-slider',                     type: 'scale'   },
					{ sel: '[class*="-img-wrap"]',           type: 'scale'   },
					{ sel: '[class*="-photos"]',             type: 'scale'   },
					{ sel: 'section img',                    type: 'scale'   },
					{ sel: '.kunstner-spotify',              type: 'scale'   },
					{ sel: '.kunstner-social-icons',         type: 'up'      },
					{ sel: '.praktisk-faq-item',             type: 'fade'    },
					{ sel: '[class*="-quote"]',              type: 'up'      },
					{ sel: '[class*="-meta"]',               type: 'up'      },
				];

				// Tildel animationstype (første match vinder)
				ANIM_MAP.forEach(({ sel, type }) => {
					document.querySelectorAll(sel).forEach(el => {
						if (!shouldSkip(el) && !el.hasAttribute('data-anim')) {
							el.setAttribute('data-anim', type);
						}
					});
				});

				// Fjern data-anim fra elementer der er indlejret i et allerede-animeret element
				document.querySelectorAll('[data-anim] [data-anim]').forEach(el => {
					el.removeAttribute('data-anim');
				});

				// Stagger: søskende i samme forælder animerer lidt forskudt
				const seen = new Set<Element>();
				document.querySelectorAll('[data-anim]').forEach(el => {
					const parent = el.parentElement;
					if (!parent || seen.has(parent)) return;
					seen.add(parent);
					const siblings = Array.from(parent.children).filter(c => c.hasAttribute('data-anim'));
					if (siblings.length > 1) {
						siblings.forEach((sib, i) => {
							(sib as HTMLElement).style.transitionDelay = `${i * 0.08}s`;
						});
					}
				});

				// Observer
				const io = new IntersectionObserver((entries) => {
					entries.forEach(e => {
						if (e.isIntersecting) {
							e.target.classList.add('is-visible');
							io.unobserve(e.target);
						}
					});
				}, { threshold: 0.1, rootMargin: '0px 0px -32px 0px' });

				document.querySelectorAll('[data-anim]').forEach(el => io.observe(el));
			})();
		</script>

	</body>
</html>