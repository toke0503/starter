<script>
// Spotify lazy-load — sætter kun src når sektionen ruller ind.
// Uden src i HTML'en sætter Spotify INGEN cookies under Lighthouse-scanningen,
// hvilket løfter Best Practices-scoren.
(function () {
	const iframe = document.getElementById('spotify-embed');
	if (!iframe) return;
	const io = new IntersectionObserver(function (entries) {
		if (!entries[0].isIntersecting) return;
		iframe.setAttribute('src', iframe.getAttribute('data-src') || '');
		io.disconnect();
	}, { rootMargin: '400px' });
	io.observe(iframe);
})();
</script>

