<!-- Keyframes skal være i is:global for at undgå Astros scoping af animationsnavne -->
<style is:global>
	/*
	 * -50% er relativt til elementets EGEN bredde (= de to spors samlede bredde).
	 * Dvs. vi translater præcis ét spors bredde — sømløst loop uanset skærmstørrelse.
	 */
	@keyframes marquee-scroll {
		from { transform: translateX(0); }
		to   { transform: translateX(-50%); }
	}

	@media (max-width: 768px) {
		[data-marquee] { animation-duration: 40s !important; }
	}

	/* Fejlmeddelelser — visibility i stedet for display så layout ikke skubbes */
	.newsletter-error {
		visibility: hidden;
		font-family: var(--font-body);
		font-size: 0.875rem;
		color: var(--color-rod);
		font-style: italic;
	}

	/* Placeholder-farve på nyhedsbrev-inputs */
	.newsletter-input::placeholder {
		color: var(--color-sand);
		opacity: 0.65;
	}

	/* Custom checkbox */
	.newsletter-cb-box {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 1.375rem;
		height: 1.375rem;
		border: 3px solid var(--color-rod);
		border-radius: 0.3rem;
		flex-shrink: 0;
		margin-top: 0.2rem;
		background: transparent;
		transition: background 0.15s ease;
	}

	.newsletter-cb-input:checked + .newsletter-cb-box {
		background: var(--color-rod);
	}

	/* Sand-farvet checkmark via clip-path */
	.newsletter-cb-input:checked + .newsletter-cb-box::after {
		content: '';
