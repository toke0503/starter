---
import MainLayout from "../layouts/MainLayout.astro";
import billetMaskotRaw from "../assets/svg/billet_maskot.svg?raw";
import armbaandRaw from "../assets/svg/armband.svg?raw";
import carRaw from "../assets/svg/car.svg?raw";
import teltRaw from "../assets/svg/telt.svg?raw";
import glampingRaw from "../assets/svg/glamping.svg?raw";
import Button from "../components/Button.astro";
import "../styles/billet.css";

const TICKET_URL = "https://billet.unitedtickets.dk/event/midtfyn-festival-2026/midtfyns-festival/3491074#op1";
---

<MainLayout title="Køb Billet – Midtfyns Festival">

	<!-- Hero -->
	<section class="billet-hero">
		<div class="billet-hero-inner">

			<!-- Maskot -->
			<div class="billet-mascot" set:html={billetMaskotRaw}></div>

			<!-- Overskrift -->
			<h1 class="font-walnut billet-title">Køb billet til MF26</h1>

			<!-- Undertekst -->
			<h4 class="billet-sub">
				Scroll ned og find din foretrukne billet til dage fyldt med musik, fællesskab og lange sommeraftener på Midtfyn.
			</h4>

		</div>

		<!-- Armbånd-illustration -->
		<div class="billet-hero-armbaand" set:html={armbaandRaw} aria-hidden="true"></div>
	</section>

	<!-- Armbånd-sektion -->
	<section class="billet-armbaand">

		<h2 class="font-walnut billet-armbaand-title">Armbånd</h2>

		<div class="billet-grid">

			<!-- Partout -->
			<article class="billet-card">
				<div class="billet-card-top">
					<h4 class="billet-card-name">Partout</h4>
					<p class="billet-card-desc">
						Med et partoutarmbånd får du adgang til hele Midtfyns Festival, alle dage.
					</p>
					<p class="billet-card-desc">
						Det vil sige, alle koncerter, festivalområdet og camping hele weekenden.
					</p>
				</div>
				<div class="billet-card-bottom">
					<h3 class="billet-card-price">1.285,-</h3>
					<Button variant="primary" size="small" href={TICKET_URL} target="_blank">Køb billet</Button>
				</div>
			</article>

			<!-- Børne Partout -->
			<article class="billet-card">
				<div class="billet-card-top">
					<h4 class="billet-card-name">Børne Partout</h4>
					<p class="billet-card-subtitle">Børn fra 6 år t.o.m 12 år</p>
					<p class="billet-card-desc">
						Med et partoutarmbånd får du adgang til hele Midtfyns Festival, alle dage.
					</p>
				</div>
				<div class="billet-card-bottom">
					<h3 class="billet-card-price">245,-</h3>
					<Button variant="primary" size="small" href={TICKET_URL} target="_blank">Køb billet</Button>
				</div>
			</article>

			<!-- Ungdomsbillet -->
			<article class="billet-card">
				<div class="billet-card-top">
					<h4 class="billet-card-name">Ungdomsbillet</h4>
					<p class="billet-card-subtitle">Unge imellem 13–17. årige</p>
					<p class="billet-card-desc">
						Giver adgang til hele Midtfyns Festival, alle dage.
					</p>
				</div>
				<div class="billet-card-bottom">
					<h3 class="billet-card-price">910,-</h3>
					<Button variant="primary" size="small" href={TICKET_URL} target="_blank">Køb billet</Button>
				</div>
			</article>

			<!-- Dagbillet Fredag -->
			<article class="billet-card">
				<div class="billet-card-top">
					<h4 class="billet-card-name">Dagbillet Fredag</h4>
					<p class="billet-card-desc">
						Adgang til hele Midtfyns Festival om Fredagen
					</p>
				</div>
				<div class="billet-card-bottom">
					<h3 class="billet-card-price">860,-</h3>
					<Button variant="primary" size="small" href={TICKET_URL} target="_blank">Køb billet</Button>
				</div>
			</article>

			<!-- Dagbillet Lørdag -->
			<article class="billet-card">
				<div class="billet-card-top">
					<h4 class="billet-card-name">Dagbillet Lørdag</h4>
					<p class="billet-card-desc">
						Adgang til hele Midtfyns Festival om Lørdagen
					</p>
				</div>
				<div class="billet-card-bottom">
					<h3 class="billet-card-price">860,-</h3>
					<Button variant="primary" size="small" href={TICKET_URL} target="_blank">Køb billet</Button>
				</div>
			</article>

		</div>

		<!-- Bølge: Rød → Grøn -->
		<div class="billet-wave-rod-gron" aria-hidden="true"></div>

	</section>

	<!-- Overnatning-sektion -->
	<section class="billet-overnatning" style="padding-top: 18rem;">

		<h2 class="font-walnut billet-overnatning-title">Overnatning</h2>

		<!-- Bil og telt illustrationer -->
		<div class="billet-overnatning-deko" aria-hidden="true">
			<div class="billet-deko-svg billet-deko-car" set:html={carRaw}></div>
			<div class="billet-deko-svg billet-deko-telt" set:html={teltRaw}></div>
		</div>

		<div class="billet-grid">

			<!-- Camping Billet Voksen -->
			<article class="billet-card">
				<div class="billet-card-top">
					<h4 class="billet-card-name">Camping Billet Voksen</h4>
					<p class="billet-card-desc">Bo tæt på festivalen og vågn midt i stemningen. På campingområdet er der plads til både campingvogne og camplette.</p>
				</div>
				<div class="billet-card-bottom">
					<h3 class="billet-card-price">380,-</h3>
					<Button variant="primary" size="small" href={TICKET_URL} target="_blank">Køb billet</Button>
				</div>
			</article>

			<!-- Camping Billet Barn -->
			<article class="billet-card">
				<div class="billet-card-top">
					<h4 class="billet-card-name">Camping Billet Barn</h4>
					<p class="billet-card-desc">Bo tæt på festivalen og vågn midt i stemningen. På campingområdet er der plads til både campingvogne og camplette.</p>
				</div>
				<div class="billet-card-bottom">
					<h3 class="billet-card-price">165,-</h3>
					<Button variant="primary" size="small" href={TICKET_URL} target="_blank">Køb billet</Button>
				</div>
			</article>

			<!-- Telt -->
			<article class="billet-card">
				<div class="billet-card-top">
					<h4 class="billet-card-name">Telt</h4>
					<p class="billet-card-desc">Tag teltet med og gør festivaloplevelsen komplet med camping tæt på pladsen og fællesskabet.</p>
				</div>
				<div class="billet-card-bottom">
					<h3 class="billet-card-price">110,-</h3>
					<Button variant="primary" size="small" href={TICKET_URL} target="_blank">Køb billet</Button>
				</div>
			</article>

			<!-- Camplet -->
			<article class="billet-card">
				<div class="billet-card-top">
					<h4 class="billet-card-name">Camplet</h4>
					<p class="billet-card-desc">Bo tæt på festivalen i camplet og vågn op midt i musik, fællesskab og sommerstemning.</p>
				</div>
				<div class="billet-card-bottom">
					<h3 class="billet-card-price">395,-</h3>
					<Button variant="primary" size="small" href={TICKET_URL} target="_blank">Køb billet</Button>
				</div>
			</article>

			<!-- Campingvogn & Autocamper -->
			<article class="billet-card">
				<div class="billet-card-top">
					<h4 class="billet-card-name">Campingvogn &amp; Autocamper</h4>
					<p class="billet-card-desc">Tag campingvognen eller autocamperen med og nyd festivalweekenden med komfort tæt på musik, fællesskab og sommerstemning.</p>
				</div>
				<div class="billet-card-bottom">
					<h3 class="billet-card-price">395,-</h3>
					<Button variant="primary" size="small" href={TICKET_URL} target="_blank">Køb billet</Button>
				</div>
			</article>

			<!-- Campingvogn m. Fortelt/Markise -->
			<article class="billet-card">
				<div class="billet-card-top">
					<h4 class="billet-card-name">Campingvogn m. Fortelt/Markise</h4>
					<p class="billet-card-desc">Skab jeres egen lille festivalbase med campingvogn, fortelt eller markise.</p>
				</div>
				<div class="billet-card-bottom">
					<h3 class="billet-card-price">1.015,-</h3>
					<Button variant="primary" size="small" href={TICKET_URL} target="_blank">Køb billet</Button>
				</div>
			</article>

			<!-- Pavillon -->
			<article class="billet-card">
				<div class="billet-card-top">
					<h4 class="billet-card-name">Pavillon</h4>
					<p class="billet-card-desc">Gør campingområdet til jeres egen lille festivalbase med en pavillon til hygge og samvær.</p>
				</div>
				<div class="billet-card-bottom">
					<h3 class="billet-card-price">510,-</h3>
					<Button variant="primary" size="small" href={TICKET_URL} target="_blank">Køb billet</Button>
				</div>
			</article>

		</div>
	</section>

	<!-- Glamping-sektion -->
	<section class="billet-overnatning" style="padding-bottom: 20rem;">

		<h2 class="font-walnut billet-overnatning-title">Glamping</h2>

		<!-- Glamping-illustration -->
		<div class="billet-glamping-deko" set:html={glampingRaw} aria-hidden="true"></div>

		<div class="billet-grid billet-grid--2col">

			<!-- B&B Glamping 2 personer — All inclusive -->
			<article class="billet-card">
				<div class="billet-card-top">
					<h4 class="billet-card-name">B&amp;B Glamping 2 personer — All inclusive</h4>
					<p class="billet-card-desc">B&amp;B All Inclusive inkluderer færdig camp, morgenmad og fuld adgang til Midtfyns Festival for 2 personer.</p>
				</div>
				<div class="billet-card-bottom">
					<h3 class="billet-card-price">7.245,-</h3>
					<Button variant="primary" size="small" href={TICKET_URL} target="_blank">Køb billet</Button>
				</div>
			</article>

			<!-- B&B Glamping 2 personer -->
			<article class="billet-card">
				<div class="billet-card-top">
					<h4 class="billet-card-name">B&amp;B Glamping 2 personer</h4>
					<p class="billet-card-desc">Glamping B&amp;B er til jer, der allerede har købt partoutbillet og ønsker ekstra komfort under festivalen.</p>
				</div>
				<div class="billet-card-bottom">
					<h3 class="billet-card-price">4.245,-</h3>
					<Button variant="primary" size="small" href={TICKET_URL} target="_blank">Køb billet</Button>
				</div>
			</article>

		</div>

		<!-- Bølge: Grøn → Sand (footer) -->
		<div class="billet-wave-gron-sand" aria-hidden="true"></div>

	</section>

</MainLayout>
