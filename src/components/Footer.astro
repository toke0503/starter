---
import logoSvgRaw from '../assets/svg/logo.svg?raw';
---

<footer style="background: var(--color-sand); padding: 5.5rem 3rem 4.5rem;">
	<div style="max-width: 1100px; margin: 0 auto; text-align: center;">

		<!-- Maskot -->
		<div class="footer-mascot" set:html={logoSvgRaw} style="margin-bottom: 2.25rem;"></div>

		<!-- MIDTFYNS FESTIVAL -->
		<h1
			class="font-walnut footer-title"
			style="color: var(--color-rod); text-transform: uppercase; line-height: 0.95; margin-bottom: 1rem;"
		>Midtfyns Festival</h1>

		<!-- Tagline -->
		<p class="footer-tagline" style="color: var(--color-rod); margin-bottom: 5rem;">
			Af græsrødder &amp; Ildsjæle
		</p>

		<!-- 3 kolonner -->
		<div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 3rem; margin-bottom: 4.5rem;">

			<!-- Foreningen -->
			<div>
				<h4 style="color: var(--color-rod); margin-bottom: 1rem;">Foreningen</h4>
				<address style="font-style: normal; font-family: var(--font-acumin); font-size: 1rem; line-height: 1.85; color: var(--color-rod);">
					Lombjergevej 20<br/>
					5750 Ringe<br/>
					Danmark<br/>
					CVR: 39609304
				</address>
			</div>

			<!-- Generel kontakt -->
			<div>
				<h4 style="color: var(--color-rod); margin-bottom: 1rem;">Generel kontakt</h4>
				<a
					href="mailto:info@midtfynsfestival.dk"
					style="font-family: var(--font-acumin); font-size: 1rem; color: var(--color-rod); text-decoration: none;"
					class="footer-email"
				>info@midtfynsfestival.dk</a>
			</div>

			<!-- Bliv frivillig -->
			<div>
				<h4 style="color: var(--color-rod); margin-bottom: 1rem;">Bliv frivillig</h4>
				<p style="font-family: var(--font-acumin); font-size: 1rem; color: var(--color-rod); margin: 0;">
					Skriv til <a href="/kontakt" class="footer-link">frivilligkordinatoren</a> →
				</p>
			</div>

		</div>

		<!-- Sociale medier -->
		<div style="display: flex; justify-content: center; gap: 0.75rem;">
			<a href="https://instagram.com/midtfynsfestival" target="_blank" rel="noopener" class="footer-social">
				<svg width="42" height="42" viewBox="0 0 42 42" fill="none">
					<circle cx="21" cy="21" r="20" stroke="var(--color-rod)" stroke-width="1.5"/>
					<rect x="12.5" y="12.5" width="17" height="17" rx="5" stroke="var(--color-rod)" stroke-width="1.5"/>
					<circle cx="21" cy="21" r="4.25" stroke="var(--color-rod)" stroke-width="1.5"/>
					<circle cx="26" cy="16" r="1" fill="var(--color-rod)"/>
				</svg>
			</a>
			<a href="https://facebook.com/midtfynsfestival" target="_blank" rel="noopener" class="footer-social">
				<svg width="42" height="42" viewBox="0 0 42 42" fill="none">
					<circle cx="21" cy="21" r="20" stroke="var(--color-rod)" stroke-width="1.5"/>
					<path d="M22.5,16H24.5V13.5H22C19.8,13.5 18.5,15 18.5,17V18.5H16.5V21H18.5V28.5H21.5V21H23.5L24,18.5H21.5V17C21.5,16.4 21.9,16 22.5,16Z" fill="var(--color-rod)"/>
				</svg>
			</a>
			<a href="https://tiktok.com/@midtfynsfestival" target="_blank" rel="noopener" class="footer-social">
				<svg width="42" height="42" viewBox="0 0 42 42" fill="none">
					<circle cx="21" cy="21" r="20" stroke="var(--color-rod)" stroke-width="1.5"/>
					<path d="M25,14.5C25,16.5 26.5,18 28.5,18V20.5C27,20.5 25.7,20 24.5,19.2V24.5C24.5,27 22.5,29 20,29C17.5,29 15.5,27 15.5,24.5C15.5,22 17.5,20 20,20C20.3,20 20.6,20 20.9,20.1V22.6C20.6,22.5 20.3,22.5 20,22.5C18.9,22.5 18,23.4 18,24.5C18,25.6 18.9,26.5 20,26.5C21.1,26.5 22,25.6 22,24.5V14.5H25Z" fill="var(--color-rod)"/>
				</svg>
			</a>
		</div>

	</div>
</footer>

<style>
	/* ── Maskot: tilsidesæt SVG-dimensioner og fill-farve ── */
	:global(.footer-mascot) {
		display: flex;
		justify-content: center;
	}
	:global(.footer-mascot svg) {
		width: 210px;
		height: auto;
	}
	:global(.footer-mascot svg path) {
		fill: var(--color-rod);
	}

	/* ── MIDTFYNS FESTIVAL — stor walnut-overskrift ── */
	.footer-title {
		font-size: clamp(4.5rem, 9vw, 8.5rem);
		white-space: nowrap;
	}

	/* ── Tagline — geller lidt større end standard p ── */
	.footer-tagline {
		font-size: 1.85rem;
	}

	/* ── Email hover ── */
	.footer-email {
		transition: opacity 0.2s ease;
	}
	.footer-email:hover {
		opacity: 0.7;
	}

	/* ── Frivillig-link: understreg ── */
	.footer-link {
		font-family: var(--font-acumin);
		font-size: 1rem;
		color: var(--color-rod);
		text-decoration: underline;
		text-underline-offset: 3px;
	}
	.footer-link:hover {
		opacity: 0.7;
	}

	/* ── Sociale ikoner ── */
	.footer-social {
		transition: opacity 0.2s ease;
	}
	.footer-social:hover {
		opacity: 0.65;
	}
</style>
