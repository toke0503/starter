---
// Henter parametrene fra Astro.props
const { htmlheading="h2", size, font, stylingclasses="", class: userClass="" } = Astro.props;
const Htmlheading = htmlheading;

// Hvis der ikke er angivet en font, vælg walnut for h1/h2 og acumin for h3/h4
const fontProp = font ?? (htmlheading === 'h1' || htmlheading === 'h2' ? 'walnut' : 'acumin');

// Flydende størrelser: clamp(mobil, fluid, desktop)
const defaultSizeByHeading: Record<string, string> = {
	"h1": "clamp(2.25rem, 11.8vw, 10.625rem)",  // 36px → 170px
	"h2": "clamp(1.5rem, 3.5vw, 3.25rem)",       // 24px → 52px
	"h3": "clamp(1rem, 2.75vw, 2.625rem)",        // 16px → 42px
	"h4": "clamp(1rem, 2vw, 1.6875rem)",          // 16px → 27px
};

const sizeValues: Record<string, string> = {
	"large":   "clamp(2.25rem, 11.8vw, 10.625rem)",
	"medium":  "clamp(1.5rem, 3.5vw, 3.25rem)",
	"small":   "clamp(1rem, 2.75vw, 2.625rem)",
	"xsmall":  "clamp(1rem, 2vw, 1.6875rem)",
};

const resolvedFontSize = size ? sizeValues[size] : defaultSizeByHeading[htmlheading];

//Definer den styling (Tailwind classes), der gør sig gældende for de forskellige skrifttyper.
const fontClasses: Record<string, string> = {
	"display": "font-walnut",
	"sans":    "font-acumin",
	"serif":   "font-body",
	"walnut":  "font-walnut",
	"acumin":  "font-acumin",
	"body":    "font-body",
};
---
<Htmlheading style={`font-size: ${resolvedFontSize};`} class:list={[stylingclasses, fontClasses[fontProp], userClass]}><slot /></Htmlheading>